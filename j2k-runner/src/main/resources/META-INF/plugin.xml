<idea-plugin>
    <id>io.github.zxuhan.j2k.runner</id>
    <name>j2k batch runner</name>
    <vendor>zxuhan</vendor>
    <description><![CDATA[
        Headless driver for the bundled Java-to-Kotlin converter (NJ2K / K2 J2K).
        Registers a `j2k-batch` ApplicationStarter that converts a directory of
        Java files via the j2kConverterExtension extension point.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <appStarter
            id="j2k-batch"
            implementation="io.github.zxuhan.j2k.J2kApplicationStarter"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
    </extensions>
</idea-plugin>
